{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "baseUrl": ".",
    "types": ["siyuan"],
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*", "node_modules/siyuan/**/*.d.ts"]
}
